# Optional provider selection for auto_from_env.
# If LLM_PROVIDER is omitted, LLM Switchboard uses litellm.
LLM_PROVIDER=litellm
MODEL_NAME=openai/gpt-4o-mini

# LiteLLM forwards provider-specific environment variables as needed.
OPENAI_API_KEY=

# OpenAI / Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=ollama

# Watsonx
WX_API_KEY=
WX_PROJECT_ID=
WX_URL="https://us-south.ml.cloud.ibm.com"

# Enterprise/internal integrations
RITS_API_KEY=
RITS_API_URL="https://inference-3scale-apicast-production.apps.rits.fmaas.res.ibm.com"
IBM_THIRD_PARTY_API_KEY=
IBM_LITELLM_API_BASE="https://ete-litellm.bx.cloud9.ibm.com"

# Logging
LLM_SWITCHBOARD_LOG_LEVEL=INFO
LLM_SWITCHBOARD_LOG_DIR=
